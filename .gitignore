# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out of git; .env.example is safe to commit (placeholders only)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# Circle entity secret recovery (never commit)
/recovery/

# vercel
.vercel

# prisma sqlite
/prisma/dev.db
/prisma/dev.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts
