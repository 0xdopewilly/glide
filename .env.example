# Circle — server only (never expose to the browser)
CIRCLE_API_KEY=
CIRCLE_KIT_KEY=
CIRCLE_ENTITY_SECRET=
# CIRCLE_WALLET_SET_ID=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Database ───────────────────────────────────────────────────────────────
# Local dev (SQLite) — default, no account needed
DATABASE_URL="file:./dev.db"

# Production (Neon Postgres, free tier): https://neon.tech
# 1. Create project → copy connection string
# 2. In prisma/schema.prisma change provider to "postgresql"
# 3. Set DATABASE_URL below (use pooled URL for serverless / Vercel)
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
