# Circle — server only (never expose to the browser)
CIRCLE_API_KEY=
# Kit Key for swap/bridge — format KIT_KEY:keyId:keySecret (NOT TEST_API_KEY)
# https://developers.circle.com/w3s/keys#kit-keys
# Local only (.env.local). Production: Vercel env vars + redeploy. Check /api/health/kit
CIRCLE_KIT_KEY=
# Optional alias (same value as CIRCLE_KIT_KEY):
# KIT_KEY=
# STABLECOIN_KIT_API_KEY=
CIRCLE_ENTITY_SECRET=

# Groq — Glide AI assistant (server only)
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Web Push (payment alerts) — generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# CIRCLE_WALLET_SET_ID=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Supabase Postgres (production) ─────────────────────────────────────────
# Dashboard → Project Settings → Database
#
# DATABASE_URL = "Connection pooling" (Transaction mode, port 6543)
#   postgresql://postgres.[ref]:[PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL = "Direct connection" (port 5432) — used by Prisma migrations only
#   postgresql://postgres.[ref]:[PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:5432/postgres
#
DATABASE_URL=
DIRECT_URL=
