// Production Postgres (Supabase). Use pooled URL for the app, direct URL for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Glide user — Clerk id is the primary key.
model User {
  id                   String        @id
  email                String        @unique
  displayName          String?
  /// Unique handle for sends — set once during onboarding (e.g. khadee).
  username             String?       @unique
  avatarUrl            String?
  circleWalletId       String?       @unique
  circleWalletAddress  String?
  /// Billy's chat history, last ~80 messages. Synced across devices.
  chatHistory          Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  transactions         Transaction[]
  contacts             Contact[]
  pushSubscriptions    PushSubscription[]
  paymentRequests      PaymentRequest[]
  scheduledTransfers   ScheduledTransfer[]
  notifications        Notification[]
  walletAddresses      WalletAddress[]
}

/// Per-chain Circle wallet for Universal Receive (CCTP V2 sweep into Arc).
/// One row per (userId, chain). Arc is implicit on User.circleWalletId; this
/// table is for *additional* receive chains (Base, Ethereum, Polygon, Arbitrum).
model WalletAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// e.g. "BASE-SEPOLIA", "ETH-SEPOLIA", "MATIC-AMOY", "ARB-SEPOLIA".
  chain     String
  walletId  String   @unique
  address   String
  createdAt DateTime @default(now())

  @@unique([userId, chain])
  @@index([address])
}

/// In-app inbox for payments, requests, and activity alerts.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

/// Shareable payment request (link + QR).
model PaymentRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       String
  /// USDC or EURC on Arc.
  token        String   @default("USDC")
  note         String?
  code         String   @unique
  status       String   @default("pending")
  paidByUserId String?
  /// Who the requester asked to pay (optional).
  targetUserId       String?
  requestFromEmail   String?
  requestFromGlideTag String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

/// Recurring / scheduled send (processed by cron).
model ScheduledTransfer {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination     String
  recipientLabel  String?
  amount          String
  note            String?
  frequency       String
  nextRunAt       DateTime
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, active, nextRunAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Saved payees — name + wallet for quick sends.
model Contact {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  walletAddress String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, walletAddress])
  @@index([userId, name])
}

/// On-chain activity mirrored from Circle + App Kit (source of truth: chain).
model Transaction {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind                String
  title               String
  amountLabel         String
  variant             String
  status              String?
  /// One Circle tx creates ONE activity row PER user (debit on sender, credit
  /// on recipient). Uniqueness is (userId, circleTransactionId), not the id alone.
  circleTransactionId String?
  txHash              String?
  explorerUrl         String?
  chain               String?
  /// Source chain when funds arrived via cross-chain CCTP sweep (e.g. "Base").
  /// Null for native Arc transfers.
  originChain         String?
  metadata            Json?
  pushNotified        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, circleTransactionId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([txHash])
  @@index([circleTransactionId])
}
