// Production Postgres (Supabase). Use pooled URL for the app, direct URL for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Glide user — Clerk id is the primary key.
model User {
  id                   String        @id
  email                String        @unique
  displayName          String?
  /// Unique handle for sends — set once during onboarding (e.g. khadee).
  username             String?       @unique
  avatarUrl            String?
  circleWalletId       String?       @unique
  circleWalletAddress  String?
  /// Dedicated "Savings" Circle wallet, provisioned lazily the first time the
  /// user creates an auto-save automation. Separate from the spending wallet.
  savingsWalletId      String?       @unique
  savingsWalletAddress String?
  /// Billy's chat history, last ~80 messages. Synced across devices.
  chatHistory          Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  transactions         Transaction[]
  contacts             Contact[]
  pushSubscriptions    PushSubscription[]
  paymentRequests      PaymentRequest[]
  scheduledTransfers   ScheduledTransfer[]
  notifications        Notification[]
  walletAddresses      WalletAddress[]
  automationRules      AutomationRule[]
  approvalPolicy       ApprovalPolicy?
  pendingApprovals     PendingApproval[]
}

/// Per-chain Circle wallet for Universal Receive (CCTP V2 sweep into Arc).
/// One row per (userId, chain). Arc is implicit on User.circleWalletId; this
/// table is for *additional* receive chains (Base, Ethereum, Polygon, Arbitrum).
model WalletAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// e.g. "BASE-SEPOLIA", "ETH-SEPOLIA", "MATIC-AMOY", "ARB-SEPOLIA".
  chain     String
  walletId  String   @unique
  address   String
  createdAt DateTime @default(now())

  @@unique([userId, chain])
  @@index([address])
}

/// In-app inbox for payments, requests, and activity alerts.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

/// Shareable payment request (link + QR).
model PaymentRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       String
  /// USDC or EURC on Arc.
  token        String   @default("USDC")
  note         String?
  code         String   @unique
  status       String   @default("pending")
  paidByUserId String?
  /// Who the requester asked to pay (optional).
  targetUserId       String?
  requestFromEmail   String?
  requestFromGlideTag String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

/// Recurring / scheduled send (processed by cron).
model ScheduledTransfer {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination     String
  recipientLabel  String?
  amount          String
  note            String?
  frequency       String
  nextRunAt       DateTime
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, active, nextRunAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Saved payees — name + wallet for quick sends.
model Contact {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  walletAddress String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, walletAddress])
  @@index([userId, name])
}

/// On-chain activity mirrored from Circle + App Kit (source of truth: chain).
model Transaction {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind                String
  title               String
  amountLabel         String
  variant             String
  status              String?
  /// One Circle tx creates ONE activity row PER user (debit on sender, credit
  /// on recipient). Uniqueness is (userId, circleTransactionId), not the id alone.
  circleTransactionId String?
  txHash              String?
  explorerUrl         String?
  chain               String?
  /// Source chain when funds arrived via cross-chain CCTP sweep (e.g. "Base").
  /// Null for native Arc transfers.
  originChain         String?
  /// Source-chain txHash for Universal Receive. Unique so Circle webhook
  /// retries can't trigger duplicate sweeps — DB rejects the second insert
  /// atomically, no read-then-write race window.
  bridgeSourceTxHash  String?  @unique
  metadata            Json?
  pushNotified        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, circleTransactionId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([txHash])
  @@index([circleTransactionId])
}

/// A user-defined automation rule — the Rules Engine. MVP: event-triggered
/// auto-save ("save N% of every payment received"). Designed to generalize to
/// schedule- and threshold-triggered rules later (trigger/action are strings).
model AutomationRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Human-readable label, e.g. "Auto-save 10% of income".
  name      String
  /// What fires the rule. MVP: "payment_received". Future: "schedule", "threshold".
  trigger   String
  /// What the rule does. MVP: "save".
  action    String
  /// Percentage 1–100 for percent-based actions (save N%). Null otherwise.
  percent   Int?
  /// Fixed amount for schedule send actions (e.g. rent "1200.00").
  amount          String?
  /// Destination for send/threshold actions: 0x address, @username, or the
  /// sentinel "savings".
  destination     String?
  /// Display label for the destination (e.g. "@landlord", "Savings").
  recipientLabel  String?
  /// Schedule cadence for trigger "schedule": "daily" | "weekly" | "monthly".
  frequency       String?
  /// Next fire time for schedule rules (cron picks these up).
  nextRunAt       DateTime?
  /// Last execution time (bookkeeping / dashboard).
  lastRunAt       DateTime?
  /// Threshold ceiling for trigger "threshold": keep balance at/under this and
  /// sweep the excess to savings.
  thresholdAmount String?
  /// Token the rule operates on.
  token     String   @default("USDC")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runs      AutomationRun[]

  @@index([userId, active])
  @@index([userId, trigger, active])
  @@index([trigger, active, nextRunAt])
}

/// One execution of an AutomationRule — the Automation Dashboard's history.
/// `sourceRef` is the triggering transaction id; the unique (ruleId, sourceRef)
/// makes execution idempotent so webhook retries can't double-save.
model AutomationRun {
  id          String   @id @default(cuid())
  ruleId      String
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId      String
  /// "completed" | "failed".
  status      String
  /// Plain-language summary, e.g. "Saved $10.00 (10%) from a $100.00 payment".
  summary     String
  amountLabel String?
  /// Triggering source (e.g. the incoming Circle tx id) — idempotency key.
  sourceRef   String?
  /// Resulting save-transfer's Circle tx id.
  resultTxId  String?
  error       String?
  createdAt   DateTime @default(now())

  @@unique([ruleId, sourceRef])
  @@index([userId, createdAt(sort: Desc)])
}

/// Per-user permissions for automated actions (Approval & Permissions Engine).
/// Automations at/under autoApproveUnder execute automatically; larger ones (or
/// new-recipient payments when required) create a PendingApproval instead.
model ApprovalPolicy {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// USD amount; automated actions at/under this auto-approve. Null = approve all.
  autoApproveUnder       String?
  /// Require approval when an automation pays a recipient not in the user's contacts.
  requireForNewRecipient Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

/// An automated action held for the user's explicit approval (F3).
model PendingApproval {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Originating rule, if any.
  ruleId         String?
  /// The action awaiting approval: "send" | "save".
  action         String
  amount         String
  token          String   @default("USDC")
  destination    String
  recipientLabel String?
  /// Why approval is required, e.g. "Above your $500 auto-approve limit".
  reason         String
  /// pending | approved | rejected | executed | failed
  status         String   @default("pending")
  /// Idempotency key for the triggering event.
  sourceRef      String?
  resultTxId     String?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
}
